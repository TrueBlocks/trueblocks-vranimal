# Switch selector
ROUTE CLOCK.fraction_changed TO SWITCH_SEL.set_fraction
ROUTE SWITCH_SEL.value_changed TO SPLITTER.whichChoice

# Green plane (cut 1)
ROUTE CLOCK.fraction_changed TO CUT1_POS.set_fraction
ROUTE CUT1_POS.value_changed TO CUTTER1.set_translation

# Red plane (cut 2)
ROUTE CLOCK.fraction_changed TO CUT2_POS.set_fraction
ROUTE CUT2_POS.value_changed TO CUTTER2.set_translation

# Blue plane (cut 3)
ROUTE CLOCK.fraction_changed TO CUT3_POS.set_fraction
ROUTE CUT3_POS.value_changed TO CUTTER3.set_translation

# Halves (choice 1)
ROUTE CLOCK.fraction_changed TO HALF1_POS.set_fraction
ROUTE HALF1_POS.value_changed TO HALF1.set_translation
ROUTE CLOCK.fraction_changed TO HALF2_POS.set_fraction
ROUTE HALF2_POS.value_changed TO HALF2.set_translation

# Quarters (choice 2)
ROUTE CLOCK.fraction_changed TO Q0_POS.set_fraction
ROUTE Q0_POS.value_changed TO Q0.set_translation
ROUTE CLOCK.fraction_changed TO Q1_POS.set_fraction
ROUTE Q1_POS.value_changed TO Q1.set_translation
ROUTE CLOCK.fraction_changed TO Q2_POS.set_fraction
ROUTE Q2_POS.value_changed TO Q2.set_translation
ROUTE CLOCK.fraction_changed TO Q3_POS.set_fraction
ROUTE Q3_POS.value_changed TO Q3.set_translation

# Octants (choice 3)
ROUTE CLOCK.fraction_changed TO O0_POS.set_fraction
ROUTE O0_POS.value_changed TO O0.set_translation
ROUTE CLOCK.fraction_changed TO O1_POS.set_fraction
ROUTE O1_POS.value_changed TO O1.set_translation
ROUTE CLOCK.fraction_changed TO O2_POS.set_fraction
ROUTE O2_POS.value_changed TO O2.set_translation
ROUTE CLOCK.fraction_changed TO O3_POS.set_fraction
ROUTE O3_POS.value_changed TO O3.set_translation
ROUTE CLOCK.fraction_changed TO O4_POS.set_fraction
ROUTE O4_POS.value_changed TO O4.set_translation
ROUTE CLOCK.fraction_changed TO O5_POS.set_fraction
ROUTE O5_POS.value_changed TO O5.set_translation
ROUTE CLOCK.fraction_changed TO O6_POS.set_fraction
ROUTE O6_POS.value_changed TO O6.set_translation
ROUTE CLOCK.fraction_changed TO O7_POS.set_fraction
ROUTE O7_POS.value_changed TO O7.set_translation

# Colored octants (choice 4)
ROUTE CLOCK.fraction_changed TO CO0_POS.set_fraction
ROUTE CO0_POS.value_changed TO CO0.set_translation
ROUTE CLOCK.fraction_changed TO CO1_POS.set_fraction
ROUTE CO1_POS.value_changed TO CO1.set_translation
ROUTE CLOCK.fraction_changed TO CO2_POS.set_fraction
ROUTE CO2_POS.value_changed TO CO2.set_translation
ROUTE CLOCK.fraction_changed TO CO3_POS.set_fraction
ROUTE CO3_POS.value_changed TO CO3.set_translation
ROUTE CLOCK.fraction_changed TO CO4_POS.set_fraction
ROUTE CO4_POS.value_changed TO CO4.set_translation
ROUTE CLOCK.fraction_changed TO CO5_POS.set_fraction
ROUTE CO5_POS.value_changed TO CO5.set_translation
ROUTE CLOCK.fraction_changed TO CO6_POS.set_fraction
ROUTE CO6_POS.value_changed TO CO6.set_translation
ROUTE CLOCK.fraction_changed TO CO7_POS.set_fraction
ROUTE CO7_POS.value_changed TO CO7.set_translation
