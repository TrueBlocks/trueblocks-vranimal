#VRML V2.0 utf8

Viewpoint {
  position 0 0 5
  description "Front"
}

Background {
  skyColor [ 0.05 0.05 0.15 ]
}

DirectionalLight {
  direction -0.5 -1 -0.5
  intensity 0.9
}

Transform {
  children [
    Shape {
      appearance Appearance {
        material Material {
          diffuseColor 1 1 1
          shininess 0.8
        }
        texture ImageTexture {
          url "leaves.jpg"
        }
      }
      geometry Sphere { radius 1.5 }
    }
  ]
}
