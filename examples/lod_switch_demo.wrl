#VRML V2.0 utf8

# LOD & Switch Demo
# - LOD: Walk closer/farther to see detail levels change
# - Switch: Click the blue box to cycle whichChoice (red/green/blue spheres)

NavigationInfo { headlight TRUE type "WALK" speed 5 }
Viewpoint { position 0 2 15 description "Start" }

# --- LOD: three detail levels at different distances ---
Transform {
  translation -4 1 0
  children [
    LOD {
      center 0 0 0
      range [ 10, 25 ]
      level [
        # Close: detailed (red box + yellow sphere)
        Group {
          children [
            Shape {
              appearance Appearance { material Material { diffuseColor 1 0 0 } }
              geometry Box { size 1 1 1 }
            }
            Transform {
              translation 0 1.2 0
              children [
                Shape {
                  appearance Appearance { material Material { diffuseColor 1 1 0 } }
                  geometry Sphere { radius 0.3 }
                }
              ]
            }
          ]
        }
        # Medium: simpler (green box)
        Shape {
          appearance Appearance { material Material { diffuseColor 0 1 0 } }
          geometry Box { size 1 1 1 }
        }
        # Far: minimal (blue sphere)
        Shape {
          appearance Appearance { material Material { diffuseColor 0 0 1 } }
          geometry Sphere { radius 0.5 }
        }
      ]
    }
  ]
}

# --- Switch: cycle through 3 colored spheres on click ---
Transform {
  translation 4 1 0
  children [
    DEF SwitchGroup Group {
      children [
        DEF Toggler TouchSensor {}
        DEF Cycler Switch {
          whichChoice 0
          choice [
            Shape {
              appearance Appearance { material Material { diffuseColor 1 0 0 } }
              geometry Sphere { radius 1 }
            }
            Shape {
              appearance Appearance { material Material { diffuseColor 0 1 0 } }
              geometry Sphere { radius 1 }
            }
            Shape {
              appearance Appearance { material Material { diffuseColor 0 0 1 } }
              geometry Sphere { radius 1 }
            }
          ]
        }
      ]
    }
  ]
}

# Timer drives a scalar interpolator that outputs 0,1,2 cycling whichChoice
DEF ClickTimer TimeSensor { cycleInterval 3 loop TRUE enabled FALSE }
DEF ChoiceInterp ScalarInterpolator {
  key [ 0, 0.33, 0.66, 1.0 ]
  keyValue [ 0, 1, 2, 0 ]
}

ROUTE Toggler.touchTime TO ClickTimer.startTime
ROUTE ClickTimer.fraction_changed TO ChoiceInterp.set_fraction
ROUTE ChoiceInterp.value_changed TO Cycler.whichChoice

# --- Floor ---
Transform {
  translation 0 -0.05 0
  children [
    Shape {
      appearance Appearance { material Material { diffuseColor 0.4 0.4 0.4 } }
      geometry Box { size 20 0.1 20 }
    }
  ]
}
